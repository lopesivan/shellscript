#!/usr/bin/env python3
"""
Gerenciador de Histórico do Bash com SQLite
Armazena comandos únicos sem limite de 1000 linhas
"""

import sqlite3
import sys
import os
from pathlib import Path
from typing import List, Optional
import argparse
from datetime import datetime


class HistoryManager:
    def __init__(self, db_path: Optional[str] = None):
        """Inicializa o gerenciador de histórico"""
        if db_path is None:
            db_path = str(Path.home() / ".bash_history.db")

        self.db_path = db_path
        self.conn = None
        self.history_file = Path.home() / ".bash_history"

    def __enter__(self):
        """Context manager para gerenciar conexão"""
        self.conn = sqlite3.connect(self.db_path)
        self.conn.row_factory = sqlite3.Row
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        """Fecha conexão ao sair"""
        if self.conn:
            self.conn.close()

    def create_db(self):
        """Cria a tabela se não existir"""
        cursor = self.conn.cursor()
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS commands (
                command TEXT PRIMARY KEY NOT NULL,
                first_seen TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                last_seen TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """)
        self.conn.commit()
        print(f"✓ Banco de dados criado/verificado: {self.db_path}")

    def add_command(self, command: str, update_last_seen: bool = True) -> bool:
        """
        Adiciona um comando ao banco

        Args:
            command: Comando a ser adicionado
            update_last_seen: Se True, atualiza last_seen em caso de duplicata

        Returns:
            True se comando foi adicionado, False se já existia
        """
        command = command.strip()

        # Ignora comandos vazios ou muito curtos
        if not command or len(command) < 2:
            return False

        # Ignora comandos que começam com espaço (feature do bash para não salvar)
        if command.startswith(' '):
            return False

        cursor = self.conn.cursor()

        try:
            if update_last_seen:
                # Tenta inserir, se já existir, atualiza last_seen
                cursor.execute("""
                    INSERT INTO commands (command, first_seen, last_seen)
                    VALUES (?, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
                    ON CONFLICT(command) DO UPDATE SET last_seen=CURRENT_TIMESTAMP
                """, (command,))
            else:
                # Apenas tenta inserir, ignora se já existir
                cursor.execute("""
                    INSERT OR IGNORE INTO commands (command) VALUES (?)
                """, (command,))

            self.conn.commit()
            return cursor.rowcount > 0

        except sqlite3.Error as e:
            print(f"✗ Erro ao adicionar comando: {e}", file=sys.stderr)
            return False

    def search_with_timestamps(self, query: Optional[str] = None, limit: int = 50) -> List[tuple]:
        """
        Busca comandos retornando também os timestamps

        Returns:
            Lista de tuplas (last_seen, command)
        """
        cursor = self.conn.cursor()

        if query is None or query.strip() == "":
            cursor.execute("""
                SELECT command, last_seen FROM commands
                ORDER BY last_seen DESC
                LIMIT ?
            """, (limit,))
        else:
            cursor.execute("""
                SELECT command, last_seen FROM commands
                WHERE command LIKE ?
                ORDER BY last_seen DESC
                LIMIT ?
            """, (f'%{query}%', limit))

        return [(row['last_seen'], row['command']) for row in cursor.fetchall()]

    def import_history(self, verbose: bool = True) -> tuple[int, int]:
        """
        Importa comandos do .bash_history

        Returns:
            Tupla (total_processado, novos_adicionados)
        """
        if not self.history_file.exists():
            print(f"✗ Arquivo não encontrado: {self.history_file}")
            return (0, 0)

        total = 0
        added = 0

        try:
            with open(self.history_file, 'r', encoding='utf-8', errors='ignore') as f:
                for line in f:
                    command = line.strip()
                    if command:
                        total += 1
                        if self.add_command(command, update_last_seen=False):
                            added += 1

            self.conn.commit()

            if verbose:
                print(f"✓ Processados: {total} comandos")
                print(f"✓ Novos adicionados: {added}")
                print(f"✓ Total único no banco: {self.count()}")

            return (total, added)

        except Exception as e:
            print(f"✗ Erro ao importar histórico: {e}", file=sys.stderr)
            return (0, 0)

    def search(self, query: Optional[str] = None, limit: int = 50) -> List[str]:
        """
        Busca comandos no banco

        Args:
            query: Termo de busca (None = mostra últimos)
            limit: Número máximo de resultados

        Returns:
            Lista de comandos encontrados
        """
        cursor = self.conn.cursor()

        if query is None or query.strip() == "":
            cursor.execute("""
                SELECT command FROM commands
                ORDER BY last_seen DESC
                LIMIT ?
            """, (limit,))
        else:
            cursor.execute("""
                SELECT command FROM commands
                WHERE command LIKE ?
                ORDER BY last_seen DESC
                LIMIT ?
            """, (f'%{query}%', limit))

        return [row['command'] for row in cursor.fetchall()]

    def list_commands(self, limit: int = 50, reverse: bool = True) -> List[tuple]:
        cursor = self.conn.cursor()
        order = "DESC" if reverse else "ASC"
        cursor.execute(f"""
            SELECT first_seen, command FROM commands
            ORDER BY last_seen {order}   -- era first_seen, muda pra last_seen
            LIMIT ?
        """, (limit,))
        results = cursor.fetchall()
        return [(row['first_seen'], row['command']) for row in results]

